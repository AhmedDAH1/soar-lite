# Application Configuration
APP_NAME=SOAR-Lite
APP_VERSION=1.0.0
DEBUG=false

# Database (choose one)
# SQLite (Development):
# DATABASE_URL=sqlite:///./soar_lite.db

# PostgreSQL (Production):
DATABASE_URL=postgresql://soar_user:your_password@localhost:5432/soar_lite

# API Keys (Required for IOC enrichment)
VIRUSTOTAL_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Security (Production)
SECRET_KEY=generate_a_random_secret_key_here
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
